{
  "compilerOptions": {
    "target": "esnext",
    "baseUrl": ".",
    "rootDir": "src",
    "module": "nodenext",
    "paths": {
      "~/*": ["src/*"]
    },
    "types": ["node"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true
  },
  "include": ["src"]
}
